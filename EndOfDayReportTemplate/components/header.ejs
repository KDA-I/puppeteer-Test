<style>
    .eod-header {
        /* padding: 24px 28px; */
        border-radius: 8px;
        margin-bottom: 32px;
        page-break-inside: avoid;
    }

    .eod-header-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 16px;
    }

    .eod-title {
        font-size: 22px;
        font-weight: 700;
        color: #1f2937;
        line-height: 24px;
        margin: 0 0 6px;
    }

    .eod-subtitle {
        font-size: 8px;
        font-weight: 600;
        color: rgba(97, 97, 97, 1);
        text-transform: uppercase;
        line-height: 20px;
        margin: 0;
    }

    .eod-generated {
        text-align: right;
        font-size: 10px;
        color: rgba(97, 97, 97, 1);
        line-height: 12px;
        white-space: nowrap;
    }

    .eod-generated-name {
        font-weight: 600;
    }

    .eod-generated-time {
        color:rgba(138, 138, 138, 1);
        font-size: 8px;
        line-height: 16px;
        font-weight: 400;
    }

    .eod-accent {
        width: 40px;
        height: 6px;
        background: <%= primaryColor || '#0f766e' %>;
        margin-left: auto;
        margin-top: 8px;
    }

    .eod-header-bottom {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .eod-logo {
        width: 56px;
        height: 56px;
        border-radius: 8px;
        background: #e5e7eb;
        overflow: hidden;
        flex-shrink: 0;
    }

    .eod-logo img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .eod-org-tag {
        font-size: 8px;
        font-weight: 600;
        line-height: 12px;
        color:rgba(97, 97, 97, 1);
        text-transform: uppercase;
        /* margin-bottom: 4px; */
    }

    .eod-org-name {
        font-size: 12px;
        line-height: 16px;
        font-weight: 700;
        color: rgba(26, 26, 26, 1);
    }

    .eod-org-meta {
        font-size: 10px;
        line-height: 16px;
        font-weight: 400;
        color: rgba(97, 97, 97, 1);
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        row-gap: 0px;
    }


</style>

<div class="eod-header">
    <div class="eod-header-top">
        <div>
            <h1 class="eod-title">END OF THE REPORT</h1>
            <p class="eod-subtitle">YOUR CLINIC'S COMPLETE DAILY FINANCIAL & ACTIVITY REPORT</p>
        </div>
        <div class="eod-generated">
            GENERATED BY <span class="eod-generated-name">SIMPLIVET</span><br>
            <span class="eod-generated-time">
            <%= new Date(generatedTime).toLocaleDateString('en-US', { weekday: 'short', day: '2-digit', month: 'short', year: 'numeric', timeZone: 'Asia/Kolkata' }) %>
            <%= new Date(generatedTime).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', timeZone: 'Asia/Kolkata' }) %></span>
            <div class="eod-accent"></div>
        </div>
    </div>

    <div class="eod-header-bottom">
        <% if (organization && organization.logo) { %>
            <div class="eod-logo">
                <img src="<%= organization.logo %>" alt="Logo" onerror="this.style.display='none'">
            </div>
        <% } %>
        <div>
            <div class="eod-org-tag"><%= organization?.name || '' %></div>
            <div class="eod-org-name"><%= organization?.branchName || organization?.name || '' %></div>
            <div class="eod-org-meta">
                <span><%= organization?.address || '-' %> <%- organization.email ? '• ' + organization.email : '' %></span>
            </div>
        </div>
    </div>
</div>
