<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <style>
    * {
      font-family: Inter, 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', sans-serif;
    }

    .page-number {
        color:rgba(138, 138, 138, 1);
        font-size: 7px;
        text-transform: capitalize;
        line-height: 12px;
        font-weight: 500;
        font-style: "Roboto Mono", monospace;
        margin: 10px 20px;
    }
  </style>
</head>
<body>
<div
class="page-number"
  style="
    display: flex;
    justify-content: space-between;
    width: 100%;
  "
>
  <div style="font-weight: 600; margin: 0px;  text-transform: capitalize;">
    Powered By Simplivet 
  </div>
  <div >
    <p>
      Page <span class="pageNumber"></span> of <span class="totalPages"></span>
    </p>
    <div></div>
  </div>
</div>
</body>
</html>
