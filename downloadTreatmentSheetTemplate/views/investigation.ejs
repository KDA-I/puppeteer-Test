<style>
  .investigation-table {
    border-collapse: collapse;
    width: 100%;
    color: #000000;
    margin: 0px 0px 10px 0px;

    p {
      padding: 0px ;
      margin: 0px;
    }
  }

  .investigation-header {
    display: flex;
    color: #666666;
    font-size: 12px;
    font-weight: 600;
    border-bottom: 1px solid #d6d6d6;
  }

  .investigation-header .col-index {
    flex: 0.01;
    padding: 8px;
    margin: 0px 5px 0px 0px;
  }

  .investigation-header .col-test-group {
    flex: 0.4;
    padding: 8px;
    margin: 0px 5px 0px 0px;
  }

  .investigation-header .col-recorded-at {
    flex: 0.2;
    padding: 8px;
    margin: 0px 5px 0px 0px;
  }

  .investigation-header .col-items {
    flex: 0.5;
    padding: 8px;
    margin: 0px 5px 0px 0px;
  }

  .investigation-row {
    display: flex;
    font-size: 12px;
    font-weight: 600;
    border-bottom: 1px solid #d6d6d6;
  }

  .investigation-row:last-child {
    border-bottom: none;
  }

  .investigation-row .col-index {
    flex: 0.01;
    padding: 8px;
    background-color: #ffff;
    margin: 0px 5px 0px 0px;
  }

  .investigation-row .col-test-group {
    flex: 0.4;
    padding: 8px;
    background-color: #ffff;
    margin: 0px 5px 0px 0px;
  }



  .investigation-row .col-recorded-at {
    flex: 0.2;
    padding: 8px;
    background-color: #ffff;
    margin: 0px 5px 0px 0px;
  }

  .investigation-row .col-items {
    flex: 0.5;
    padding: 8px;
    background-color: #ffff;
    margin: 0px 5px 0px 0px;
  }

  .investigation-items-list {
    margin: 0px;
    padding: 0px 0px 0px 20px;
  }

  .investigation-item-comment {
    font-size: 10px;
    margin: 4px 0px 6px 0px;
    padding: 0px 0px 0px 20px;
    font-weight: 400;
  }

  .investigation-empty {
    margin: 0px;
  }

  .owner-status-label {
    font-weight: 500;
    font-size: 10px;
    margin: 10px 0px 0px 0px;
    padding: 0px;
  }

  .owner-status-value {
    font-size: 10px;
    font-weight: 400;
    overflow-wrap: anywhere;
  }

  .owner-status-confirmed {
    color: #0d9c6a;
     font-weight: 600;

  }

  .owner-status-recommended {
    color: #b28400;
     font-weight: 600;
  }

  .owner-status-rejected {
    color: #c62828;
     font-weight: 600;
  }

  .owner-status-unknown {
    color: #666666;
     font-weight: 600;
  }

  .investigation-group-meta {
    margin: 6px 0px 0px 0px;
  }
</style>

<div class="investigationSubWrapper">
  <% if (items.length > 0) { %>
  <div class="investigation-table">
    <div class="investigation-header">
      <div class="col-index">#</div>
      <div class="col-test-group">TestGroup Name</div>
      <div class="col-recorded-at">Recorded At</div>
      <div class="col-items">Investigation Items</div>
    </div>

    <% items.forEach((entry, index) => { %>
    <div class="investigation-row no-page-break">
      <div class="col-index"><%= index + 1 %></div>
      <div class="col-test-group">
        <p><%= entry.name %></p>

        <% if(entry.ownerStatus ||entry.description ) { %>
          <div class="investigation-group-meta ">
        <% if(entry.ownerStatus) { %>
        <p class="owner-status-label">Owner Status:<span class="owner-status-value <%= entry.ownerStatus === 'CONFIRMED' ? 'owner-status-confirmed' : entry.ownerStatus === 'RECOMMENDED' ? 'owner-status-recommended' : entry.ownerStatus === 'REJECTED' ? 'owner-status-rejected' : 'owner-status-unknown' %>" >  
          
        <%= entry.ownerStatus === 'CONFIRMED' ? 'Confirmed' : entry.ownerStatus === 'RECOMMENDED' ? 'Recommended' :
          entry.ownerStatus === 'REJECTED' ? 'Rejected' : 'Unknown Status' %>
        </p>
     
        <% } %>
        
        <% if(entry.description) { %>
        <p class="owner-status-label">Description:
 <span style="font-size: 10px; font-weight: 400; margin: 0px; padding: 0px; overflow-wrap: anywhere; hyphens: auto">
          <%= entry.description %>
        </span>

        </p>
       
        <% } %>
            </div>
        <% } %>


      </div>
      <div class="col-recorded-at">
        <%= new Date(entry.createdAt).toLocaleDateString() %>
      </div>
      <div class="col-items">
        <% if (entry.result && entry.result.resultItems && entry.result.resultItems.length > 0) { %>
        <ul class="investigation-items-list">
          <% entry.result.resultItems.forEach((item) => { %>
            <div style="margin-top:4px">
          <li><%= item.displayName %></li>
          <p class="investigation-item-comment"><%= item.comments %></p>
          </div>
          <% }) %>
        </ul>
        <% } else { %>
        <p class="investigation-empty">-</p>
        <% } %>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</div>
