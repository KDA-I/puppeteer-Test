<style>
  table {
    table-layout: fixed;
    width: 100%;
  }

  table th {
    border-bottom: 1px solid #cccccc;
    padding: 6px 0px;
    text-align: left;
    font-size: 8px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase; 
    line-height: 12px;
    opacity: 0.85
  }
  td {
    vertical-align: top;
    font-size: 10px;
  }

  .word-wrap {
    word-break: break-word;
    overflow-wrap: anywhere;
    
  }

  /* table th:nth-child(1),
  table td:nth-child(1) {
    max-width: 18px;
    width: 18px;
  } */

  table th.col-desc,
  table td.col-desc {
    max-width: 120px;
    width: 120px;
    text-align: start;
    vertical-align: top;
  }

  table th.col-qty,
  table td.col-qty {
    max-width: 28px;
    width: 28px;
    text-align: center;
    vertical-align: top;
  }

  table th.col-rate,
  table td.col-rate {
    max-width: 53px;
    width: 53px;
    text-align: end;
    vertical-align: top;
  }

  table th.col-amount,
  table td.col-amount {
    max-width: 56px;
    width: 56px;
    text-align:end;
    vertical-align: top;
  }

  .number-cell {
    font-family: "Roboto Mono", monospace;
    font-stretch: condensed;
  }

  .number-text {
    font-family: "Roboto Mono", monospace;
    font-stretch: condensed;
  }
</style>

<%
  const safeLineItems = Array.isArray(lineItems) ? lineItems : [];
  const toAmount = value => {
    const parsed = Number(value);
    return Number.isFinite(parsed) ? parsed.toFixed(2) : '0.00';
  };

  const toCurrency = value => {
    const parsed = Number(value);
    return Number.isFinite(parsed) ? `${currencySymbol}${parsed.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}` : `${currencySymbol}0.00`;
  };

     const formatedBatchAndExpiry = b => {
      const expiry = new Date(b.expiryDate).toLocaleDateString('en-GB', { month: 'short', year: '2-digit' });
        return `Batch ${b.batchNumber} / Exp: ${expiry}`;
      
      }
%>

<table>
  <thead>
    <tr>
      <th class="word-wrap col-desc">ITEM NAME & HSN/SAC</th>
      <th class="word-wrap col-qty">Qty</th>
      <th class="word-wrap col-rate">Rate<br /><%- organization?.isTaxesEnabled ? `(Excl. Tax)` : `(Inc. DISC.)` %></th>
      <th class="text-right word-wrap col-amount">Amount <br />(Inc. Tax)</th>
    </tr>
  </thead>

  <tbody>
    <% safeLineItems.forEach((item, index) => { %>
    <tr>
      <td class="word-wrap col-desc" style="display: flex; flex-direction: column;">
       <span style="font-weight: 600" class="word-wrap"> <%= item?.itemName || 'N/A' %></span>
        <div class="word-wrap" style="font-size: 7px; font-weight: 400; margin-top: 2px; font-family: 'Roboto Mono', monospace; font-stretch: condensed;">
          <% if (item?.hsn || item?.sac) { %>
            <%- (item.hsn) ? `HSN: ${item.hsn}` : '' %>
            <%- (item.sac) ? `${item.hsn ? ' • ' : ''}SAC: ${item.sac}` : '' %>
          <% } %>
        </div>
        <% if (Array.isArray(item?.batches) && item.batches.length > 0) { %>
          <% item.batches.forEach((batch, batchIndex) => { %>
              <div class="word-wrap" style="font-size: 7px; font-weight: 400; margin-top: 2px; font-family: 'Roboto Mono', monospace; font-stretch: condensed;">
                <%= formatedBatchAndExpiry(batch) %>
              </div>
          <% }) %>
        <% } %>
        <br />
        <% if (organization?.isTaxesEnabled && Array.isArray(item?.taxes) && item.taxes.length > 0) { %>
      
          <div class="word-wrap" style="font-size: 7px; font-weight: 400; margin-top: 2px; font-family: 'Roboto Mono', monospace; font-stretch: condensed;">
            <% item.taxes.forEach((tax, idx) => { %>
              <%= tax.code %> (<span class="number-text"><%= parseFloat(tax.percent) %></span>%) <span class="number-text"><%= toCurrency(tax.taxValuePerLineItemQuantity) %></span><% if (idx < item.taxes.length - 1) { %> / <% } %>
            <% }) %>
          </div>
        <% } %>
      </td>

      <td class="word-wrap number-cell col-qty" style=" font-weight: 500;"> <%= parseFloat(item.quantity) || '' %>  </td>

      <td class="word-wrap number-cell col-rate" style=" font-weight: 500;"><%= organization?.isTaxesEnabled ? toCurrency(item.rateExcludingTax) : toCurrency(item.taxableValuePerUnitAfterDiscount) %>
        <% if(item?.discount && Number(item.discount.discountValue) > 0) { %>
        <div style="font-size: 7px;  font-weight: 400; margin-top: 2px; font-family: 'Roboto Mono', monospace; font-stretch: condensed;">
         Disc <span class="number-text"><%- parseFloat(item.discount.discountValue) %></span>%  
        </div>
        <div style="font-size: 7px; font-weight: 400; font-family: 'Roboto Mono', monospace; font-stretch: condensed;">
          (-<span class="number-text"><%= toCurrency(item.discount.discountAmountPerUnit) %></span>)
        </div>
        <% } %>
      </td>
      <td class="text-right word-wrap number-cell col-amount">
        <span style="font-weight: 700;">
        <% if(item?.lineItemTotalAmount || item?.lineItemTotalAmount === 0) { %> <%= toCurrency(item.lineItemTotalAmount) %> <% } else { %> N/A
        <% } %> 
        </span>
      </td>
    </tr>
    <% }) %>
  </tbody>

</table>
