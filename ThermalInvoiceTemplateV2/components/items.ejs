<style>
  table {
    table-layout: fixed;
    width: 100%;
  }

  table th {
    border-bottom: 1px solid #cccccc;
    padding: 6px 0px;
    text-align: left;
    font-size: 8px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase; 
    line-height: 12px;
    opacity: 0.85
  }
  td {
    vertical-align: top;
    font-size: 10px;
  }

  .word-wrap {
    word-break: break-word;
    overflow-wrap: anywhere;
  }

  /* table th:nth-child(1),
  table td:nth-child(1) {
    max-width: 18px;
    width: 18px;
  } */

  table th:nth-child(1),
  table td:nth-child(1) {
    max-width: 120px;
    width: 120px;
    text-align: start;
    vertical-align: top;
  }

  table th:nth-child(2),
  table td:nth-child(2) {
    max-width: 28px;
    width: 28px;
    text-align: center;
    vertical-align: top;

  }

  table th:nth-child(3),
  table td:nth-child(3) {
    max-width: 50px;
    width: 50px;
    text-align: end;
    vertical-align: top;

  }

  table th:nth-child(4),
  table td:nth-child(4) {
    max-width: 56px;
    width: 56px;
    text-align:end;
    vertical-align: top;
  }

  .number-cell {
    font-family: "Roboto Mono", monospace;
    font-stretch: condensed;
  }

  .number-text {
    font-family: "Roboto Mono", monospace;
    font-stretch: condensed;
  }
</style>

<%
  const safeLineItems = Array.isArray(lineItems) ? lineItems : [];
  const toAmount = value => {
    const parsed = Number(value);
    return Number.isFinite(parsed) ? parsed.toFixed(2) : '0.00';
  };
%>

<table>
  <thead>
    <tr>
      <th class="word-wrap">ITEM NAME & HSN/SAC</th>
      <th class="word-wrap" >Qty</th>
      <th class="word-wrap" >Rate<br />(Excl.Tax)</th>
      <th class="text-right word-wrap">Amount <br />(Inc. Tax)</th>
    </tr>
  </thead>

  <tbody>
    <% safeLineItems.forEach((item, index) => { %>
    <tr>
      <td class="word-wrap" style="display: flex; flex-direction: column;">
       <span style="font-weight: 600" class="word-wrap"> <%= item?.itemName || 'N/A' %></span>
        <div class="word-wrap" style="font-size: 7px; font-weight: 400; margin-top: 2px; font-family: 'Roboto Mono', monospace; font-stretch: condensed;">
          <% if (item?.hsn || item?.sac) { %>
            <%- (item.hsn) ? `HSN: ${item.hsn}` : '' %>
            <%- (item.sac) ? `${item.hsn ? ' • ' : ''}SAC: ${item.sac}` : '' %>
          <% } %>
        </div>
        <% if (Array.isArray(item?.batches) && item.batches.length > 0) { %>
          <% item.batches.forEach((batch, batchIndex) => { %>
          <div class="word-wrap" style="font-size: 7px; font-weight: 400; margin-top: 2px; font-family: 'Roboto Mono', monospace; font-stretch: condensed;">
            Batch / Expiry: <%= batch.batchNumber %> / <%= batch.expiryDate %>
          </div>
          <% }) %>
        <% } %>
        <br />
        <% if (organization?.isTaxesEnabled && Array.isArray(item?.taxes) && item.taxes.length > 0) { %>
      
          <div class="word-wrap" style="font-size: 7px; font-weight: 400; margin-top: 2px; font-family: 'Roboto Mono', monospace; font-stretch: condensed;">
            <% item.taxes.forEach((tax, idx) => { %>
              <%= tax.code %> (<span class="number-text"><%= parseFloat(tax.percent) %></span>%) <%= currencySymbol %><span class="number-text"><%= tax.taxValue %></span><% if (idx < item.taxes.length - 1) { %> / <% } %>
            <% }) %>
          </div>
        <% } %>
      </td>

      <td class="word-wrap number-cell" style=" font-weight: 500;"><% if(item?.quantity || item?.quantity === 0) { %> <%= parseFloat(item.quantity) %> <% } else { %> N/A <% } %></td>

      <td class="word-wrap number-cell" style=" font-weight: 500;"><% if(item?.taxableAmount || item?.unitPrice === 0) { %> <%= toAmount(item.unitPrice) %> <% } else { %> 0 <% } %>
        <% if(item?.discount && Number(item.discount.discountValue) > 0) { %>
        <div style="font-size: 7px;  font-weight: 400; margin-top: 2px; font-family: 'Roboto Mono', monospace; font-stretch: condensed;">
         Disc <span class="number-text"><%- parseFloat(item.discount.discountValue) %></span>%  
        </div>
        <div style="font-size: 7px; font-weight: 400; font-family: 'Roboto Mono', monospace; font-stretch: condensed;">
          (-<span class="number-text"><%= toAmount(item.discount.discountAmount) %></span>)
        </div>
        <% } %>
      </td>
      <td class="text-right word-wrap number-cell">
        <span style="font-weight: 700;">
        <% if(item?.lineItemTotalAmount || item?.lineItemTotalAmount === 0) { %> <%= currencySymbol %><%= toAmount(item.lineItemTotalAmount) %> <% } else { %> N/A
        <% } %> 
        </span>
      </td>
    </tr>
    <% }) %>
  </tbody>

</table>
