<style>
  .invoice-party {
    margin: 20px 0 18px;
    color: #111;
  }

  .invoice-party-section {
    margin-bottom: 16px;
  }

  .invoice-party-label {
    margin: 0 0 4px;
    font-size: 8px;
    font-weight: 500;
    letter-spacing: 1px;
    line-height: 12px;
    text-transform: uppercase;
    opacity: 0.85;
  }

  .invoice-party-name {
    margin: 0 0 4px;
    font-size: 12px;
    line-height: 100%;
    font-weight: 600;
  }

  .invoice-party-line {
    margin: 0;
    font-size: 10px;
    line-height: 1.35;
    word-break: break-word;
  }
</style>

<%
  const customerFullName = [customerUser?.firstName, customerUser?.lastName]
    .map(value => (value || '').toString().trim())
    .filter(Boolean)
    .join(' ');
  const doctorFullName = [consultedBy?.firstName, consultedBy?.lastName]
    .map(value => (value || '').toString().trim())
    .filter(Boolean)
    .join(' ');
  const petSpecies = pet?.species || pet?.petSpecies;
  const petBreed = pet?.breed || pet?.petBreed;
  const petAgeYears = pet?.petAge?.years;
  const petAgeText = petAgeYears || petAgeYears === 0 ? `Age: ${petAgeYears} yrs` : '';
  const petSex = pet?.sex || pet?.gender || pet?.petGender;
  const petWeight = pet?.weight || pet?.petWeight;
  const petWeightUnit = pet?.weightUnit || pet?.petWeightUnit || 'kg';
  const sexText = petSex ? `Sex: ${petSex}` : '';
  const weightText = petWeight || petWeight === 0 ? `Wt: ${petWeight} ${petWeightUnit}` : '';
  const petProfileLine = [petAgeText, sexText, weightText].filter(Boolean).join(' • ');
  const petSpeciesBreed = [petSpecies, petBreed].filter(Boolean).join(' • ');
  const customerEmail = customerUser?.email || customerUser?.mail;
  const customerPhone = customerUser?.phoneNumber || customerUser?.mobile || customerUser?.contactNumber;
  const placeOfSupplyText = customerUser?.placeOfSupply || '';
%>

<div class="invoice-party">
  <div class="invoice-party-section">
    <h4 class="invoice-party-label">Bill To</h4>
    <p class="invoice-party-name"><%= customerFullName || 'N/A' %></p>
      <% if (customerPhone) { %>
    <p class="invoice-party-line"><%= customerPhone %></p>
    <% } %>
     <% if (customerEmail) { %>
    <p class="invoice-party-line"><%= customerEmail %></p>
    <% } %>
   
    <% if (customerUser?.address) { %>
    <p class="invoice-party-line"><%= customerUser.address %></p>
    <% } %>
    <% if (customerUser?.address?.state) { %>
    <p class="invoice-party-line">Place of Supply: <%= placeOfSupplyText %></p>
    <% } %>
  </div>

  <% if (pet) { %>
  <div class="invoice-party-section">
    <h4 class="invoice-party-label">Patient</h4>
    <p class="invoice-party-name"><%= pet?.petName || 'N/A' %></p>
    <% if (petSpeciesBreed) { %>
    <p class="invoice-party-line"><%= petSpeciesBreed %></p>
    <% } %> <% if (petProfileLine) { %>
    <p class="invoice-party-line"><%= petProfileLine %></p>
    <% } %>
  </div>
  <% } %>

  <% if (consultedBy) { %>
  <div class="invoice-party-section" style="margin-bottom: 0">
    <h4 class="invoice-party-label">CONSULTING DOCTOR</h4>
    <p class="invoice-party-name">Dr. <%= doctorFullName || 'N/A' %></p>
    <% if (consultedBy?.qualification || consultedBy?.highestDegree) { %>
    <p class="invoice-party-line"><%- consultedBy?.qualification || consultedBy?.highestDegree.replace(/\n/g, '<br>') %></p>
    <% } %> <% if (consultedBy?.registrationNumber || consultedBy?.veterinaryRegistrationNumber || consultedBy?.regNo) { %>
    <p class="invoice-party-line">
      Reg. No: <%= consultedBy?.registrationNumber || consultedBy?.veterinaryRegistrationNumber || consultedBy?.regNo %>
    </p>
    <% } %>
  </div>
  <% } %>
</div>
