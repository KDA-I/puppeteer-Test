<!-- items-table.ejs -->
<% const itemsPerPage = 8;
   const totalItems = (lineItems || []).length;
   const pages = [];
   for (let i = 0; i < totalItems; i += itemsPerPage) {
     pages.push((lineItems || []).slice(i, i + itemsPerPage));
   }
%>

<style>
  .invoice-items-table {
    width: 100%;
    border-collapse: collapse;
    margin: 12px 0 8px;
    border-bottom: 1px solid #000000;
  }
  .invoice-items-table th,
  .invoice-items-table td {
    border-bottom: none;
    padding: 8px 4px;
    vertical-align: top;
    font-size: 8px;
  }
  .invoice-items-table th {
    background: transparent;
    color: #6b7280;
    font-size: 7px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-align: left;
    padding-bottom: 8px;
    border-bottom: 1px solid #d1d5db;
    line-height: 10px;
  }
  .invoice-items-table .col-description {
    width: 26%;
  }
  .invoice-items-table .col-qty {
    width: 8%;
    text-align: center;
  }
  .invoice-items-table .col-rate {
    width: 15%;
    text-align: right;
  }
  .invoice-items-table .col-disc {
    width: 7%;
    text-align: end;
  }
  .invoice-items-table .col-taxable-value {
    width: 13%;
    text-align: end;
  }
  .invoice-items-table .col-cgst {
    width: 7%;
    text-align: end;
  }
  .invoice-items-table .col-sgst {
    width: 7%;
    text-align: end;
  }
  .invoice-items-table .col-igst {
    width: 7%;
    text-align: end;
  }
  .invoice-items-table .col-amount {
    width: 12%;
    text-align: right;
    font-weight: 600;
  }
  
  /* Adjusted widths when taxes are disabled */
  .invoice-items-table.no-taxes .col-description {
    width: 35%;
  }
  .invoice-items-table.no-taxes .col-rate {
    width: 14%;
  }
  .invoice-items-table.no-taxes .col-disc {
    width: 12%;
  }
  .invoice-items-table.no-taxes .col-rate-inc-disc {
    width: 16%;
    text-align: right;
  }
  .invoice-items-table.no-taxes .col-amount {
    width: 20%;
  }
  .tax-value {
    font-size: 7px;
    color: #6b7280;
    margin-top: 2px;
    font-family: "Roboto Mono", monospace;
    font-stretch: condensed;
     font-style: normal;
  }
  .item-name {
    margin: 0;
    font-size: 8px;
    font-weight: 600;
    color: #111827;
    line-height: 10px;
  }
  .item-subtext {
    margin: 2px 0 0;
    font-size: 7px;
    color: #6b7280;
    font-weight: 400;
    line-height: 10px;
    font-family: "Roboto Mono", monospace;
    font-stretch: condensed;
  }
  .money {
    white-space: nowrap;
    font-family: "Roboto Mono", monospace;
    font-stretch: condensed;
  }
  
  .page-section-break {
    page-break-after: always;
  }
  
  .turn-page-message {
    text-align: center;
  }
  
  .end-of-items {
    text-align: center;
   
  }
</style>

<% pages.forEach((pageItems, pageIndex) => { const isLastPage = pageIndex === pages.length - 1; %>
<div class="<%= isLastPage ? '' : 'page-section-break' %>">
<table class="invoice-items-table <%= !organization?.isTaxesEnabled ? 'no-taxes' : '' %>">
  <% const isIgstPresent = (lineItems || []).some(item => item?.taxes?.some(t => t.code === 'IGST' && t.percent && Number(t.percent) > 0));
    const isSgstPresent = (lineItems || []).some(item => item?.taxes?.some(t => t.code === 'SGST' && t.percent && Number(t.percent) > 0));
    const isCgstPresent = (lineItems || []).some(item => item?.taxes?.some(t => t.code === 'CGST' && t.percent && Number(t.percent) > 0));
  %>
  <thead>
    <tr>
      <th class="col-description">Item Name</th>
      <th class="col-qty">Qty</th>
      <th class="col-rate">Rate <%- organization?.isTaxesEnabled ? `(Excl. Tax)`: '' %> </th>
      <th class="col-disc">Disc.</th>
      <% if (organization?.isTaxesEnabled) { %>
        <th class="col-taxable-value">Taxable Value</th>
        <th class="col-cgst">CGST</th>
        <th class="col-sgst">SGST</th>
           <% if (isIgstPresent) { %>
        <th class="col-igst">IGST</th>
      <% } %>
      <% } %>
      <% if (!organization?.isTaxesEnabled) { %>
        <th class="col-rate-inc-disc">Rate (Inc. Disc.)</th>
      <% } %>
   
      <th class="col-amount">Amount</th>
    </tr>
  </thead>

  <tbody>
    <% pageItems.forEach(function(item) { 

      const toCurrency = value => {
        const parsed = Number(value);
        return Number.isFinite(parsed) ? `${currencySymbol}${parsed.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}` : `${currencySymbol}0.00`;
      };

      const sgstTax = item?.taxes?.find(t => t.code === 'SGST');
      const cgstTax = item?.taxes?.find(t => t.code === 'CGST');
      const igstTax = item?.taxes?.find(t => t.code === 'IGST');
      const batchInfo = item?.batches?.length ? item.batches.map(b => { 
        const formatedExpiryDate = new Date(b.expiryDate).toLocaleDateString('en-GB', { month: 'short', year: '2-digit' });
        return `Batch ${b.batchNumber} / Exp: ${formatedExpiryDate}`; }).join(', ') : '';
    %>
    <tr>
      <td class="col-description">
        <p class="item-name"><%= item?.itemName || 'Item name: N/A' %></p>
         <% if (organization?.isTaxesEnabled && (item?.hsn  || item?.sac)) { %>
        <p class="item-subtext"><%- item?.hsn ?  `HSN: ${item.hsn}` : item?.sac ? `SAC: ${item.sac}` : '' %></p>
      <% } %>
        <% if (batchInfo) { %>
          <p class="item-subtext"><%= batchInfo %></p>
        <% } %>
      </td>



      <td class="col-qty" style="vertical-align:middle; font-family: 'Roboto Mono', monospace;"><%= parseFloat(item?.quantity) %></td>


     
      <td class="col-rate money"  style="vertical-align:middle;"><%= toCurrency(item?.rateExcludingTax) %></td>





      <td class="col-disc" style="vertical-align:middle;">
          <div style="font-family: 'Roboto Mono', monospace;"><%- parseFloat(item?.discount?.discountValue) || '-' %>%</div>
          <% if (item?.discount?.discountValue) { %>
            <div class="tax-value">-<%= toCurrency(item?.discount?.discountAmountPerUnit) %></div>
          <% } %>

      </td>

      <% if (organization?.isTaxesEnabled) { %>
      <td class="col-taxable-value money" style="vertical-align:middle;"><%= toCurrency(item?.taxableValuePerUnitAfterDiscount) %></td>
        <% } %>
      
      <% if (organization?.isTaxesEnabled) { %>
        <% if(isSgstPresent && Number(sgstTax?.percent) > 0) { %>
        <td class="col-cgst"  style="vertical-align:middle;">
          <div style="font-family: 'Roboto Mono', monospace;"><%- parseFloat(sgstTax?.percent) %>%</div>
          <div class="tax-value money"><%= toCurrency(sgstTax?.taxValuePerLineItemQuantity) %></div>
        </td>
        <% } else { %> 
             <td class="col-cgst"  style="vertical-align:middle;">
          <div>-</div>
        </td>
          <% } %>
        <% if(isCgstPresent && Number(cgstTax?.percent) > 0) { %>
        <td class="col-sgst" style="vertical-align:middle;">
          <div style="font-family: 'Roboto Mono', monospace;"><%- parseFloat(cgstTax?.percent) %>%</div>
          <div class="tax-value money"  style="vertical-align:middle;"><%= toCurrency(cgstTax?.taxValuePerLineItemQuantity) %></div>
        </td>
        <% }  else { %> 
             <td class="col-sgst" style="vertical-align:middle;">
          <div>-</div>
        </td>
        <% } %>
   
      <% if (isIgstPresent && Number(igstTax?.percent) > 0) { %>
        <td class="col-igst" style="vertical-align:middle;">
          <div style="font-family: 'Roboto Mono', monospace;"><%- parseFloat(igstTax?.percent) %>%</div>
          <div class="tax-value money"><%= toCurrency(igstTax?.taxValuePerLineItemQuantity) %></div>
        </td>
      <% } %>

         <% } %>

         <% if (!organization?.isTaxesEnabled) { %>
        <td class="col-rate-inc-disc money" style="vertical-align:middle;"><%= toCurrency(item?.taxableValuePerUnitAfterDiscount) %></td>
      <% } %>



      <td class="col-amount money"  style="vertical-align:middle;"><%= toCurrency(item?.lineItemTotalAmount) %></td>
    </tr>
    <% }); %>
  </tbody>
</table>

<% if (!isLastPage) { %>
<!-- Turn page message - shown on all pages except the last -->
<div class="turn-page-message"></div>
<% } else { %>
<!-- End of items - only on last page -->
<div class="end-of-items"></div>
<% } %>
</div>
<% }); %>
