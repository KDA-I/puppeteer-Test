<!-- summary.ejs -->
<style>
  .summary-container {
    display: flex;
    gap: 30px;
    margin-top: 10px;
    width: 100%;
  }
  
  .summary-column {
    flex: 1;
  }
  
  .column-title {
    font-size: 10px;
    font-weight: 700;
    margin-bottom: 8px;
  }
  
  .summary-title {
    margin: 12px 0px;
  }
  .summary-row {
    display: flex;
    justify-content: space-between;
    padding: 3px 0;
    font-size: 8px;
  }
  
  .summary-label {
    text-align: left;
    flex: 1;
  }
  
  .summary-value {
    text-align: right;
    font-weight: 600;
    min-width: 80px;
  }
  
  .tax-breakup-row {
    display: flex;
    justify-content: space-between;
    padding: 2px 0 2px 12px;
    font-size: 8px;
    font-style: italic;
    color: #6b7280;
  }
  
  .tax-breakup-label {
    flex: 1;
  }
  
  .tax-breakup-value {
    text-align: right;
    min-width: 80px;
  }
  
  .separator-line {
    border-bottom: 1px solid #d1d5db;
    margin: 6px 0;
  }
  
  .discount-value {
    color: #dc2626;
  }
  
  .total-payable {
    font-size: 8px;
    font-weight: 700;
    padding: 6px 0;
  }
  
  .total-in-words {
    font-size: 8px;
    color: #6b7280;
    margin-top: 4px;
    text-align: right;
  }
</style>


<div class="no-page-break" style="margin-top: 10px;">

  <div class="summary-container">
    <!-- Left Column: Tax Summary -->
     <% if(isTaxesEnabled) { %>
    <div class="summary-column">
      <div class="column-title">Tax Summary</div>
      
      <!-- Taxable Value (only if taxes enabled) -->
      <% if (isTaxesEnabled) { %>
      <div class="summary-row">
        <span class="summary-label">Taxable Value (Excluding GST):</span>
        <span class="summary-value">₹<%= (Number(subTotal || 0) - Number(totalDiscountAmount || 0)).toFixed(2) %></span>
      </div>
      <% } else { %>
      <div class="summary-row">
        <span class="summary-label">Taxable Value (Excluding GST):</span>
        <span class="summary-value">Taxable Value</span>
      </div>
      <% } %>

      <!-- Tax Breakup by Rate (only if taxes enabled) -->
      <% 
        if (isTaxesEnabled && lineItems && lineItems.length > 0) {
          const taxGrouped = {};
          lineItems.forEach(item => {
            if (item.tax && item.tax.length > 0) {
              // Create unique key based on actual tax composition (not just total)
              const taxComposition = item.tax
                .map(t => `${t.code}-${t.percent}`)
                .sort()
                .join('|');
              const taxRate = item.tax.reduce((sum, t) => sum + Number(t.percent || 0), 0);
              const groupKey = `${taxComposition}`;
              
              if (!taxGrouped[groupKey]) {
                taxGrouped[groupKey] = { sgst: 0, cgst: 0, igst: 0, sgstPercent: 0, cgstPercent: 0, igstPercent: 0, taxRate: taxRate };
              }
              item.tax.forEach(t => {
                const qty = Number(item.quantity) || 1;
                const baseRate = item.unitPrice || 0;
                const discountVal = Number(item.discount?.discountValue || 0);
                const taxAmount = (baseRate * qty - discountVal) * Number(t.percent) / 100;
                
                if (t.code === 'SGST') {
                  taxGrouped[groupKey].sgst += taxAmount;
                  taxGrouped[groupKey].sgstPercent = Number(t.percent);
                } else if (t.code === 'CGST') {
                  taxGrouped[groupKey].cgst += taxAmount;
                  taxGrouped[groupKey].cgstPercent = Number(t.percent);
                } else if (t.code === 'IGST') {
                  taxGrouped[groupKey].igst += taxAmount;
                  taxGrouped[groupKey].igstPercent = Number(t.percent);
                }
              });
            }
          });

          Object.keys(taxGrouped).sort((a, b) => parseFloat(taxGrouped[b].taxRate) - parseFloat(taxGrouped[a].taxRate)).forEach(groupKey => {
            const sgst = taxGrouped[groupKey].sgst;
            const cgst = taxGrouped[groupKey].cgst;
            const igst = taxGrouped[groupKey].igst;
            const sgstPercent = taxGrouped[groupKey].sgstPercent;
            const cgstPercent = taxGrouped[groupKey].cgstPercent;
            const igstPercent = taxGrouped[groupKey].igstPercent;
            const totalTax = sgst + cgst + igst;
            const rate = taxGrouped[groupKey].taxRate;

          
      %>
      <div class="summary-row">
        <span class="summary-label"><%= rate %>% GST :</span>
        <span class="summary-value">₹<%= totalTax.toFixed(2) %></span>
      </div>
      <% if (igstPercent > 0) { %>
      <div class="tax-breakup-row">
        <span class="tax-breakup-label">IGST (<%= igstPercent %>%) :</span>
        <span class="tax-breakup-value">₹<%= igst.toFixed(2) %></span>
      </div>
      <% } else if (sgstPercent > 0 || cgstPercent > 0) { %>
      <div class="tax-breakup-row">
        <span class="tax-breakup-label">CGST (<%= cgstPercent %>%) / SGST (<%= sgstPercent %>%) :</span>
        <span class="tax-breakup-value">₹<%= cgst.toFixed(2) %> / ₹<%= sgst.toFixed(2) %></span>
      </div>
      <% } %>
      <% }); 
        } else { %>
      <div class="summary-row">
        <span class="summary-label">Tax Breakup:</span>
        <span class="summary-value">Tax Details</span>
      </div>
      <% } %>

      <div class="separator-line"></div>

      <!-- Total GST -->
      <% if (isTaxesEnabled && lineItems && lineItems.length > 0) { %>
      <div class="summary-row">
        <span class="summary-label">Total GST :</span>
        <span class="summary-value">₹<%= lineItems.reduce((sum, item) => {
          if (item.tax && item.tax.length > 0) {
            const qty = Number(item.quantity) || 1;
            const baseRate = item.unitPrice || 0;
            const discountVal = Number(item.discount?.discountValue || 0);
            return sum + item.tax.reduce((taxSum, t) => taxSum + ((baseRate * qty - discountVal) * Number(t.percent) / 100), 0);
          }
          return sum;
        }, 0).toFixed(2) %></span>
      </div>
      <% } else { %>
      <div class="summary-row">
        <span class="summary-label">Total GST :</span>
        <span class="summary-value">₹0.00</span>
      </div>
      <% } %>

      <!-- Total Invoice Value (Inc. GST) -->
      <div class="summary-row">
        <span class="summary-label">Total Invoice Value (Inc. GST):</span>
        <span class="summary-value"><%= subTotal ? '₹' + parseFloat(subTotal).toFixed(2) : '₹0.00' %></span>
      </div>
    </div>
    <% } else { %>
       <div class="summary-column" > </div>
   <% } %>
    <!-- Right Column: Payment Summary -->
    <div class="summary-column">
      
      <!-- Gross Value (Inc. Taxes) -->
      <div class="summary-row">
        <span class="summary-label">Gross Value <%- isTaxesEnabled ? '(Inc. Taxes)' : null %> :  %> </span>
        <span class="summary-value"><%= subTotal ? '₹' + parseFloat(subTotal).toFixed(2) : '₹0.00' %></span>
      </div>

      <!-- Additional Discount with percentage -->
      <% if (totalDiscountAmount && Number(totalDiscountAmount) > 0) { %>
      <div class="summary-row">
        <span class="summary-label">Additional Discount :</span>
        <span class="summary-value discount-value">- (10%) ₹<%= parseFloat(totalDiscountAmount).toFixed(2) %></span>
      </div>
      <% } else { %>
      <div class="summary-row">
        <span class="summary-label">Additional Discount :</span>
        <span class="summary-value">- ₹0.00</span>
      </div>
      <% } %>

      <!-- Sub Total (Inc. Taxes) -->
      <div class="summary-row">
        <span class="summary-label">Sub Total <%- isTaxesEnabled ? '(Inc. Taxes)' : '' %> :</span>
        <span class="summary-value">₹<%= (Number(subTotal || 0) - Number(totalDiscountAmount || 0)).toFixed(2) %></span>
      </div>

      <!-- Round Off -->
      <% if (roundOffAmount && roundOffAmount !== '0.00') { %>
      <div class="summary-row">
        <span class="summary-label">Round Off :</span>
        <span class="summary-value discount-value"><%= roundOffAmount.toString().includes('-') ? '- ' : '' %>₹<%= Math.abs(parseFloat(roundOffAmount)).toFixed(2) %></span>
      </div>
      <% } else { %>
      <div class="summary-row">
        <span class="summary-label">Round Off :</span>
        <span class="summary-value">- ₹0.00</span>
      </div>
      <% } %>

      <!-- Total (Inc. Taxes) -->
      <div class="summary-row" style="font-weight: 600;">
        <span class="summary-label" >Total <%- isTaxesEnabled ? '(Inc. Taxes)' : '' %> :</span>
        <span class="summary-value">₹<%= (Number(subTotal || 0) - Number(totalDiscountAmount || 0) + Number(roundOffAmount || 0)).toFixed(2) %></span>
      </div>

      <div class="column-title summary-title">Payment Summary</div>
      <!-- Total Invoice Value -->
      <div class="summary-row">
        <span class="summary-label">Total Invoice Value :</span>
        <span class="summary-value"><%= subTotal ? '₹' + parseFloat(subTotal).toFixed(2) : '₹0.00' %></span>
      </div>

      <!-- Amount Paid -->
      <% if (totalAmountPaid && Number(totalAmountPaid) > 0) { %>
      <div class="summary-row">
        <span class="summary-label">Amount Paid :</span>
        <span class="summary-value discount-value">- ₹<%= parseFloat(totalAmountPaid).toFixed(2) %></span>
      </div>
      <% } else { %>
      <div class="summary-row">
        <span class="summary-label">Amount Paid :</span>
        <span class="summary-value">- ₹0.00</span>
      </div>
      <% } %>

      <!-- Credits Applied -->
      <% if (creditsApplied && Number(creditsApplied) > 0) { %>
      <div class="summary-row">
        <span class="summary-label">Credits Applied :</span>
        <span class="summary-value discount-value">- ₹<%= parseFloat(creditsApplied).toFixed(2) %></span>
      </div>
      <% } else { %>
      <div class="summary-row">
        <span class="summary-label">Credits Applied :</span>
        <span class="summary-value">- ₹0.00</span>
      </div>
      <% } %>

      <!-- Write Off -->
      <% if (totalWriteOffAmount && Number(totalWriteOffAmount) > 0) { %>
      <div class="summary-row">
        <span class="summary-label">Write Off :</span>
        <span class="summary-value discount-value">- ₹<%= parseFloat(totalWriteOffAmount).toFixed(2) %></span>
      </div>
      <% } else { %>
      <div class="summary-row">
        <span class="summary-label">Write Off :</span>
        <span class="summary-value">- ₹0.00</span>
      </div>
      <% } %>

      <div class="separator-line"></div>

      <!-- Total Payable -->
      <div class="summary-row total-payable" >
        <span class="summary-label">Total Payable (INR):</span>
        <span class="summary-value" style="font-weight: 600; font-size: 12px;">₹<%= parseFloat(amountPayable || 0).toFixed(2) %></span>
      </div>
      <div class="total-in-words">
        <%= totalInWords || 'INR Zero Rupees Only' %>
      </div>
    </div>
  </div>
</div>

<!-- Comments and Terms Section -->
<div style="margin-top: 22px;">
  <% if (comments) { %>
  <div>
    <p style="font-size: 8px; margin: 0; font-weight: 500; line-height: 11px">
      <span style="font-weight: 600;">Customer Notes : </span> 
      <span style="color:#000000; opacity: 0.7; font-style: italic;"><%- comments.replace(/\n/g, '<br>') %></span>
    </p>
  </div>
  <% } %>

  <% if (customTerms) { %>
  <div style="margin-top: 8px;">
    <p style="font-size: 8px; margin: 0; font-weight: 500; line-height: 11px">
      <span style="font-weight: 600;">Terms & Conditions: </span> 
      <span style="color:#000000; opacity: 0.7;"><%- customTerms.replace(/\n/g, '<br>') %></span>
    </p>
  </div>
  <% } %>
</div>