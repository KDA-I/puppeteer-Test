<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
   <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
    <title>Thermal Invoice</title>
    <style>
      @page {
        margin: 0;
        size: 80mm auto; /* Width: 80mm, Height: auto */
      }
      body {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
        -webkit-font-smoothing: antialiased;
        font-family: Inter;
        margin: 0;
        /* padding: 10px; */
        width: 302px; /* 80mm */
        font-size: 12px;
        color: #000000;
      }
      .wrapper {
        padding: 10px;
      }
      text {
        fill: #000000;
      }
      .text-center {
        text-align: center;
      }
      .text-right {
        text-align: right;
      }
      .mb-2 {
        margin-bottom: 8px;
      }
      .bold {
        font-weight: bold;
      }
      .divider {
        border-top: 1px dashed #000;
        margin: 5px 0;
      }
      .item-row {
        display: flex;
        justify-content: space-between;
        font-size: 10px;
      }
      .word-wrap {
        word-break: break-word;
        overflow-wrap: anywhere;
      }
      table {
        width: 100%;
        font-size: 11px;
        border-collapse: separate;
        border-spacing: 0 1em;
      }
      .invoice-header-top {
    display: flex;
    justify-content: flex-end;
    font-size: 10px;
    margin-bottom: 6px;
    font-weight: 400;
  }
      /* td {
        max-width: 100px;
        padding: 2px;
        text-align: left;
      } */
    </style>
  </head>
  <body>
     <% if (isTaxesEnabled) { %>
  <div class="invoice-header-top">GSTIN: <%= organization?.gst || '[GSTIN]' %></div>
  <% } %>
  <div class="wrapper">
    <%- include('./components/header') %> <%- include('./components/customer-info') %> <%- include('./components/items')
    %> <%- include('./components/summary') %> <%- include('./components/footer') %>
  </div>
  </body>
</html>