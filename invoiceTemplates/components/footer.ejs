<%
  const normalizedCustomTerms = typeof customTerms === 'string' ? customTerms.trim() : '';
  const thankYouMessage = organization?.thankYouMessage?.trim();
%>

<div class="text-center mb-2" style="border-top: 1px solid #E6E6E6; padding-top: 12px; margin-top: 12px;">
  <% if (normalizedCustomTerms) { %>
  <div style="font-size: 8px; line-height: 12px;">
    <div style="font-weight: 600; margin-bottom: 4px; text-align: center;">Terms & Conditions:</div>
    <div style="text-align: center;"><%- normalizedCustomTerms.split('\n').join('<br>') %></div>
  </div>
  <% } %>

  <% if (thankYouMessage) { %>
  <div style="margin-top: 8px; font-size: 12px; line-height: 20px; font-weight: 600; text-align: center;">
    <%= thankYouMessage %>
  </div>
  <% } else { %>
  <div>Thank you for your business!</div>
  <% } %>

  <div style="margin-top: 4px; font-size: 7px; font-weight: 500;">Powered by Simplivet</div>
</div>
